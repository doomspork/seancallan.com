---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'Elixir School',
    url: 'https://elixirschool.com/',
    role: 'Creator',
    summary: 'Translated into 30 languages and averaging over 10K visitors a week, Elixir School is the leading resource for learning the Elixir programming language.',
    featured: true,
  },
  {
    title: 'Guardian',
    url: 'https://github.com/ueberauth/guardian',
    role: 'Core Team',
    summary: 'The go-to authentication and JWT library in the Elixir community.',
  },
  {
    title: 'Ueberauth',
    url: 'https://github.com/ueberauth/ueberauth',
    role: 'Core Team',
    summary: 'Integrate third-party OAuth into your applications with ease. Strategies for Google, Facebook, GitHub, and many more.',
  },
  {
    title: 'luagents',
    url: 'https://github.com/doomspork/luagents',
    role: 'Creator',
    summary: 'Agents that think in Lua code, inspired by smolagents. Bringing AI agent capabilities to the BEAM ecosystem.',
  },
  {
    title: 'cobblestone',
    url: 'https://github.com/doomspork/cobblestone',
    role: 'Creator',
    summary: 'A powerful data querying and transformation library for Elixir.',
  },
  {
    title: 'Minecraft Mods',
    url: 'https://www.minecraftforum.net/members/doomspork/posts',
    role: 'Creator',
    summary: 'Created the original Auto Run mod and the first Server List mod, downloaded millions of times. The Server List inspired Mojang\'s official implementation.',
  },
  {
    title: 'Elixir Fountain',
    url: 'http://elixirfountain.com/',
    role: 'Co-host',
    summary: 'The Elixir community\'s source for news and updates via podcast.',
  },
  {
    title: 'Sheriff',
    url: 'https://github.com/doomspork/sheriff',
    role: 'Creator',
    summary: 'A simple and intuitive authorization library for Plug-based applications such as Phoenix.',
  },
  {
    title: 'Slime-lang',
    url: 'https://github.com/slime-lang',
    role: 'Creator',
    summary: 'The Slim markup implementation and supporting libraries for Elixir.',
  },
  {
    title: 'Elixir-Companies.com',
    url: 'https://elixir-companies.com/',
    role: 'Creator',
    summary: 'A collection of companies that currently use Elixir in production.',
  },
];
---

<section id="projects" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 text-center">
      <span class="text-teal">/</span> Projects
    </h2>
    <p class="text-text-muted text-center mb-16 max-w-2xl mx-auto">
      From Minecraft mods downloaded millions of times to the Elixir ecosystem's most popular learning platform &mdash; if it's useful, I've probably built it with a spork.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="https://github.com/doomspork"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-teal/30 text-teal hover:bg-teal/10 hover:border-teal transition-all duration-200 font-medium"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        See more on GitHub
      </a>
      <p class="mt-4 text-text-muted text-sm">
        Enjoy the work?
        <a href="https://github.com/sponsors/doomspork" target="_blank" rel="noopener noreferrer" class="text-teal hover:text-green transition-colors">You can sponsor it.</a>
      </p>
    </div>
  </div>
</section>
